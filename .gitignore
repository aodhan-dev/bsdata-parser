node_modules/
dist/
*.tsbuildinfo

# No third-party game data is ever committed. The harness reads it from a local directory you
# point BSDATA_DIR at (see harness/oracle.ts). Belt-and-braces patterns below.
/local/
/fixtures/

# Local-only source design specs copied from the Warhost repo for reference. They name the
# downstream game/IP, so they are NEVER committed to this public repo (see CLAUDE.md hygiene rule).
/docs/_local-specs/
*.cat
*.gst
catalogue.json
oracle.json

# Local-only scripts (hardcoded paths, not portable)
/scripts/

# Local-only projector (domain-specific projection code, never committed - see CLAUDE.md).
# The committed src/project/catalogue.ts stub stays tracked; new module files added here are not.
/src/project/*.ts
!/src/project/catalogue.ts
/src/project/*/
